{
  "name": "mcp-react-devtools",
  "version": "0.4.2",
  "description": "MCP server exposing React internals (component tree, props, state, hooks) to Claude Code",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "mcp-react-devtools": "./dist/server.js"
  },
  "exports": {
    ".": "./dist/server.js",
    "./agent": "./dist/agent/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "react",
    "claude",
    "claude-code",
    "devtools",
    "debugging"
  ],
  "author": "Serhii Valko <valkoserhii@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "eslint": "^9.13.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
